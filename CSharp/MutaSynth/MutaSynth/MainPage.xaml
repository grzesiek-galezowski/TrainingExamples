<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MutaSynth.MainPage"
             Title="MutaSynth">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label Text="MutaSynth"
                   FontSize="32"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#190649, Dark=White}" />

            <Label Text="Signal flow"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <FlexLayout Direction="Row"
                        Wrap="Wrap"
                        JustifyContent="Center"
                        AlignItems="Center">

                <Border x:Name="KeyboardModuleBorder"
                        Padding="18,14"
                        Margin="0,0,12,0"
                        BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#212121}"
                        Stroke="{AppThemeBinding Light=#ACACAC, Dark=#6E6E6E}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnKeyboardModuleTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" WidthRequest="110">
                        <Label Text="KBD"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="MIDI / keyboard"
                               FontSize="12"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="→"
                       FontSize="24"
                       Margin="0,0,12,0"
                       VerticalTextAlignment="Center" />

                <Border x:Name="OscillatorModuleBorder"
                        Padding="18,14"
                        Margin="0,0,12,0"
                        BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#212121}"
                        Stroke="{AppThemeBinding Light=#ACACAC, Dark=#6E6E6E}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOscillatorModuleTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" WidthRequest="110">
                        <Label Text="OSC"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Oscillator"
                               FontSize="12"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="→"
                       FontSize="24"
                       Margin="0,0,12,0"
                       VerticalTextAlignment="Center" />

                <Border x:Name="FilterModuleBorder"
                        Padding="18,14"
                        Margin="0,0,12,0"
                        BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#212121}"
                        Stroke="{AppThemeBinding Light=#ACACAC, Dark=#6E6E6E}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterModuleTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" WidthRequest="110">
                        <Label Text="FLT"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Filter"
                               FontSize="12"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="→"
                       FontSize="24"
                       Margin="0,0,12,0"
                       VerticalTextAlignment="Center" />

                <Border x:Name="AmplifierModuleBorder"
                        Padding="18,14"
                        Margin="0,0,12,0"
                        BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#212121}"
                        Stroke="{AppThemeBinding Light=#ACACAC, Dark=#6E6E6E}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAmplifierModuleTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" WidthRequest="110">
                        <Label Text="AMP"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Amplifier"
                               FontSize="12"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="→"
                       FontSize="24"
                       Margin="0,0,12,0"
                       VerticalTextAlignment="Center" />

                <Border x:Name="OutputModuleBorder"
                        Padding="18,14"
                        BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#212121}"
                        Stroke="{AppThemeBinding Light=#ACACAC, Dark=#6E6E6E}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOutputModuleTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" WidthRequest="110">
                        <Label Text="OUT"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Audio output"
                               FontSize="12"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </FlexLayout>

            <Border Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}"
                    Stroke="{AppThemeBinding Light=#C8C8C8, Dark=#404040}"
                    StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="SelectedModuleTitleLabel"
                               Text="Keyboard"
                               FontSize="24"
                               HorizontalOptions="Start"
                               HorizontalTextAlignment="Start"
                               TextColor="{AppThemeBinding Light=#190649, Dark=White}" />
                        <Label x:Name="SelectedModuleDescriptionLabel"
                               Text="Choose your MIDI source and channel."
                               TextColor="{AppThemeBinding Light=#404040, Dark=#ACACAC}" />
                    </VerticalStackLayout>

                    <Grid x:Name="KeyboardSettingsPanel" ColumnDefinitions="Auto,*" RowDefinitions="Auto, Auto, Auto" RowSpacing="12" ColumnSpacing="12">
                        <Label Text="MIDI input" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
                        <Picker x:Name="MidiInputPicker" ItemDisplayBinding="{Binding Name}" SelectedIndexChanged="OnMidiInputChanged" VerticalOptions="Center" Grid.Row="0" Grid.Column="1" />

                        <Label Text="MIDI channel" VerticalOptions="Center" Grid.Row="1" Grid.Column="0" />
                        <Picker x:Name="MidiChannelPicker" SelectedIndexChanged="OnMidiChannelChanged" VerticalOptions="Center" Grid.Row="1" Grid.Column="1" />

                        <Button Text="Test MIDI" HorizontalOptions="Start" Clicked="OnTestMidiClicked" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" />
                    </Grid>

                    <Grid x:Name="OscillatorSettingsPanel" IsVisible="False" ColumnDefinitions="Auto, *, Auto, Auto, 45" RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="12" ColumnSpacing="16">
                        <!-- Row 0 -->
                        <Label Text="Playback" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
                        <Picker x:Name="NotePlaybackModePicker" SelectedIndexChanged="OnNotePlaybackModeChanged" VerticalOptions="Center" Grid.Row="0" Grid.Column="1" />

                        <Label Text="Semi" VerticalOptions="Center" Grid.Row="0" Grid.Column="2" />
                        <Stepper x:Name="SemiStepper" Minimum="-36" Maximum="36" Increment="1" ValueChanged="OnSemiChanged" VerticalOptions="Center" Grid.Row="0" Grid.Column="3" />
                        <Label x:Name="SemiValueLabel" Text="0 st" VerticalOptions="Center" Grid.Row="0" Grid.Column="4" />

                        <!-- Row 1 -->
                        <Label Text="Wave" VerticalOptions="Center" Grid.Row="1" Grid.Column="0" />
                        <Picker x:Name="WaveformPicker" SelectedIndexChanged="OnWaveformChanged" VerticalOptions="Center" Grid.Row="1" Grid.Column="1" />

                        <Label Text="Cents" VerticalOptions="Center" Grid.Row="1" Grid.Column="2" />
                        <Stepper x:Name="CentsStepper" Minimum="-50" Maximum="50" Increment="1" ValueChanged="OnCentsChanged" VerticalOptions="Center" Grid.Row="1" Grid.Column="3" />
                        <Label x:Name="CentsValueLabel" Text="0 ct" VerticalOptions="Center" Grid.Row="1" Grid.Column="4" />

                        <!-- Row 2 -->
                        <Label Text="BitRedux" VerticalOptions="Center" Grid.Row="2" Grid.Column="0" />
                        <Picker x:Name="BitReduxPicker" SelectedIndexChanged="OnBitReduxChanged" VerticalOptions="Center" Grid.Row="2" Grid.Column="1" />

                        <Label Text="Keytrack" VerticalOptions="Center" Grid.Row="2" Grid.Column="2" />
                        <Slider x:Name="KeytrackSlider" Minimum="0" Maximum="200" Value="100" ValueChanged="OnKeytrackChanged" VerticalOptions="Center" Grid.Row="2" Grid.Column="3" />
                        <Label x:Name="KeytrackValueLabel" Text="100%" VerticalOptions="Center" Grid.Row="2" Grid.Column="4" />

                        <!-- Row 3 -->
                        <Label Text="Logging" VerticalOptions="Center" Grid.Row="3" Grid.Column="0" />
                        <Switch x:Name="OscillatorLoggingSwitch" Toggled="OnOscillatorLoggingToggled" VerticalOptions="Center" HorizontalOptions="Start" Grid.Row="3" Grid.Column="1" />
                    </Grid>

                    <Grid x:Name="AmplifierSettingsPanel" IsVisible="False" ColumnDefinitions="Auto, *" RowDefinitions="Auto" RowSpacing="12" ColumnSpacing="12">
                        <Label Text="Volume" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="0.5" ValueChanged="OnVolumeChanged" VerticalOptions="Center" Grid.Row="0" Grid.Column="1" />
                    </Grid>

                    <Grid x:Name="FilterSettingsPanel" IsVisible="False" ColumnDefinitions="Auto, *, 45" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto" RowSpacing="12" ColumnSpacing="12">
                        <Label Text="Type" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
                        <Picker x:Name="FilterTypePicker" SelectedIndexChanged="OnFilterTypeChanged" VerticalOptions="Center" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" />

                        <Label x:Name="FilterCutoffLabel" Text="Cutoff" VerticalOptions="Center" Grid.Row="1" Grid.Column="0" />
                        <Slider x:Name="FilterCutoffSlider" Minimum="0" Maximum="128" Value="128" ValueChanged="OnFilterCutoffChanged" VerticalOptions="Center" Grid.Row="1" Grid.Column="1" />
                        <Label x:Name="FilterCutoffValueLabel" Text="128.0" VerticalOptions="Center" Grid.Row="1" Grid.Column="2" />

                        <Label Text="Resonance" VerticalOptions="Center" Grid.Row="2" Grid.Column="0" />
                        <Slider x:Name="FilterResonanceSlider" Minimum="0" Maximum="128" Value="0" ValueChanged="OnFilterResonanceChanged" VerticalOptions="Center" Grid.Row="2" Grid.Column="1" />
                        <Label x:Name="FilterResonanceValueLabel" Text="0.0" VerticalOptions="Center" Grid.Row="2" Grid.Column="2" />

                        <Label Text="Keytrack" VerticalOptions="Center" Grid.Row="3" Grid.Column="0" />
                        <Slider x:Name="FilterKeytrackSlider" Minimum="-200" Maximum="200" Value="100" ValueChanged="OnFilterKeytrackChanged" VerticalOptions="Center" Grid.Row="3" Grid.Column="1" />
                        <Label x:Name="FilterKeytrackValueLabel" Text="100%" VerticalOptions="Center" Grid.Row="3" Grid.Column="2" />

                        <Label Text="Drive" VerticalOptions="Center" Grid.Row="4" Grid.Column="0" />
                        <Slider x:Name="FilterDriveSlider" Minimum="0" Maximum="128" Value="0" ValueChanged="OnFilterDriveChanged" VerticalOptions="Center" Grid.Row="4" Grid.Column="1" />
                        <Label x:Name="FilterDriveValueLabel" Text="0.0" VerticalOptions="Center" Grid.Row="4" Grid.Column="2" />

                        <Label Text="Drive route" VerticalOptions="Center" Grid.Row="5" Grid.Column="0" />
                        <Picker x:Name="FilterDriveRoutePicker" SelectedIndexChanged="OnFilterDriveRouteChanged" VerticalOptions="Center" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" />

                        <!-- Formant additions: shown/hidden dynamically via code behind -->
                        <Label x:Name="FormantVowOrderLabel" Text="Vow Order" VerticalOptions="Center" Grid.Row="6" Grid.Column="0" IsVisible="False" />
                        <Stepper x:Name="FormantVowOrderStepper" Minimum="0" Maximum="7" Increment="1" ValueChanged="OnFormantVowOrderChanged" VerticalOptions="Center" Grid.Row="6" Grid.Column="1" IsVisible="False" />
                        <Label x:Name="FormantVowOrderValueLabel" Text="0" VerticalOptions="Center" Grid.Row="6" Grid.Column="2" IsVisible="False" />

                        <Label x:Name="FormantControlLabel" Text="Control" VerticalOptions="Center" Grid.Row="7" Grid.Column="0" IsVisible="False" />
                        <Slider x:Name="FormantControlSlider" Minimum="0" Maximum="128" Value="64" ValueChanged="OnFormantControlChanged" VerticalOptions="Center" Grid.Row="7" Grid.Column="1" IsVisible="False" />
                        <Label x:Name="FormantControlValueLabel" Text="64.0" VerticalOptions="Center" Grid.Row="7" Grid.Column="2" IsVisible="False" />
                    </Grid>

                    <Grid x:Name="OutputSettingsPanel" IsVisible="False" ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="12" ColumnSpacing="12">
                        <Label Text="Audio output" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
                        <Picker x:Name="AudioOutputPicker" ItemDisplayBinding="{Binding Name}" SelectedIndexChanged="OnAudioOutputChanged" VerticalOptions="Center" Grid.Row="0" Grid.Column="1" />

                        <Label Text="Sample rate" VerticalOptions="Center" Grid.Row="1" Grid.Column="0" />
                        <Picker x:Name="SampleRatePicker" SelectedIndexChanged="OnSampleRateChanged" VerticalOptions="Center" Grid.Row="1" Grid.Column="1" />

                        <Label Text="Buffer size" VerticalOptions="Center" Grid.Row="2" Grid.Column="0" />
                        <Picker x:Name="BufferSizePicker" SelectedIndexChanged="OnBufferSizeChanged" VerticalOptions="Center" Grid.Row="2" Grid.Column="1" />

                        <Button Text="Test audio" HorizontalOptions="Start" Clicked="OnTestAudioClicked" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Padding="16"
                    BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#141414}"
                    Stroke="{AppThemeBinding Light=#C8C8C8, Dark=#404040}"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="StatusLabel"
                           Text="Initializing..." />

                    <Label x:Name="NoteLabel"
                           Text="—"
                           FontSize="18" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
